---
import { Icon } from 'astro-icon/components'
import Logo from './Logo.astro'
import { contact } from '../data/contact'
import { services } from '../data/services'
import { serviceAreas } from '../data/service-areas'

const mainLinks = [
  { name: 'Projects', href: '/projects/' },
  { name: 'About', href: '/about/' },
  { name: 'Contact', href: '/contact/' },
]
---

<header class="bg-white/95 backdrop-blur-sm sticky top-0 z-50 border-b border-stone-100">
  <!-- Desktop-only strip; on mobile FloatingContact covers call/text -->
  <div class="hidden lg:block bg-ridge-700 text-white">
    <div class="container-wide section-padding">
      <div class="flex justify-between items-center py-2 text-sm">
        <span>Licensed General Contractor &bull; Southeast Tennessee</span>
        <div class="flex items-center gap-1">
          <span class="text-ridge-200 mr-1">{contact.phone}</span>
          <a
            href={contact.phoneHref}
            data-track="call_header"
            class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium hover:bg-white/10 transition-colors"
            title="Call"
          >
            <Icon name="lucide:phone" class="h-4 w-4" />
            <span>Call</span>
          </a>
          <a
            href={`sms:${contact.phoneRaw}`}
            data-track="text_header"
            class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium hover:bg-white/10 transition-colors"
            title="Text"
          >
            <Icon name="lucide:message-square" class="h-4 w-4" />
            <span>Text</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <nav class="container-wide section-padding" aria-label="Main navigation">
    <div class="flex items-center justify-between py-4">
      <a href="/" class="flex items-center gap-3 focus-ring rounded-lg">
        <Logo class="h-10 w-10" />
        <div class="flex flex-col">
          <span class="font-display font-semibold text-lg text-stone-900 leading-tight">Maple Ridge</span>
          <span class="text-xs text-stone-500 leading-tight">Construction & Development</span>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-8">
        <div class="relative group">
          <button
            type="button"
            class="flex items-center gap-1 text-stone-700 hover:text-ridge-600 font-medium transition-colors focus-ring rounded-lg px-2 py-1"
            aria-haspopup="true"
          >
            Services
            <Icon name="lucide:chevron-down" class="h-4 w-4" />
          </button>
          <div class="absolute left-0 top-full pt-2 w-72 hidden group-hover:block group-focus-within:block">
            <div class="bg-white rounded-xl shadow-lg border border-stone-100 overflow-hidden">
              {services.map((item) => (
                <a
                  href={item.href}
                  class="block px-4 py-3 hover:bg-ridge-50 transition-colors border-b border-stone-50 last:border-0"
                >
                  <span class="font-medium text-stone-900">{item.name}</span>
                  <span class="block text-sm text-stone-500 mt-0.5">{item.description}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <div class="relative group">
          <button
            type="button"
            class="flex items-center gap-1 text-stone-700 hover:text-ridge-600 font-medium transition-colors focus-ring rounded-lg px-2 py-1"
            aria-haspopup="true"
          >
            Service Areas
            <Icon name="lucide:chevron-down" class="h-4 w-4" />
          </button>
          <div class="absolute left-0 top-full pt-2 w-48 hidden group-hover:block group-focus-within:block">
            <div class="bg-white rounded-xl shadow-lg border border-stone-100 overflow-hidden">
              {serviceAreas.map((area) => (
                <a
                  href={`/service-areas/${area.slug}/`}
                  class="block px-4 py-2.5 hover:bg-ridge-50 transition-colors text-stone-700 hover:text-ridge-700 border-b border-stone-50 last:border-0"
                >
                  {area.name}, TN
                </a>
              ))}
            </div>
          </div>
        </div>

        {mainLinks.map((item) => (
          <a
            href={item.href}
            class="text-stone-700 hover:text-ridge-600 font-medium transition-colors focus-ring rounded-lg px-2 py-1"
          >
            {item.name}
          </a>
        ))}

        <a href="/contact/" class="btn-primary">Get a Quote</a>
      </div>

      <button
        type="button"
        id="mobile-menu-button"
        class="lg:hidden relative z-10 p-3 -mr-1 text-stone-700 hover:text-ridge-600 active:text-ridge-700 focus-ring rounded-lg"
        style="touch-action: manipulation"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="sr-only" data-label-open>Open menu</span>
        <span class="sr-only hidden" data-label-close>Close menu</span>
        <Icon name="lucide:menu" class="h-6 w-6" data-icon-menu />
        <Icon name="lucide:x" class="h-6 w-6 hidden" data-icon-close />
      </button>
    </div>

    <div id="mobile-menu" class="lg:hidden py-4 border-t border-stone-100 hidden">
      <div class="py-2">
        <span class="text-xs font-medium text-stone-400 uppercase tracking-wider px-2">Services</span>
        {services.map((item) => (
          <a
            href={item.href}
            class="block px-2 py-2 text-stone-700 hover:text-ridge-600 font-medium"
          >
            {item.name}
          </a>
        ))}
      </div>

      <div class="py-2 border-t border-stone-100 mt-2">
        <span class="text-xs font-medium text-stone-400 uppercase tracking-wider px-2">Service Areas</span>
        <div class="grid grid-cols-2 gap-x-2">
          {serviceAreas.map((area) => (
            <a
              href={`/service-areas/${area.slug}/`}
              class="block px-2 py-2 text-stone-700 hover:text-ridge-600 font-medium text-sm"
            >
              {area.name}
            </a>
          ))}
        </div>
      </div>

      <div class="py-2 border-t border-stone-100 mt-2">
        {mainLinks.map((item) => (
          <a
            href={item.href}
            class="block px-2 py-2 text-stone-700 hover:text-ridge-600 font-medium"
          >
            {item.name}
          </a>
        ))}
      </div>

      <div class="pt-4 border-t border-stone-100 mt-2 space-y-3">
        <a href="/contact/" class="btn-primary w-full">Get a Free Quote</a>
        <a href={contact.phoneHref} class="flex items-center justify-center gap-2 text-stone-700 font-medium py-2">
          <Icon name="lucide:phone" class="h-4 w-4" />
          {contact.phone}
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const button = document.getElementById('mobile-menu-button')
  const menu = document.getElementById('mobile-menu')
  const iconMenu = button?.querySelector('[data-icon-menu]') as HTMLElement | null
  const iconClose = button?.querySelector('[data-icon-close]') as HTMLElement | null
  const labelOpen = button?.querySelector('[data-label-open]') as HTMLElement | null
  const labelClose = button?.querySelector('[data-label-close]') as HTMLElement | null

  button?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false
    button.setAttribute('aria-expanded', String(isOpen))
    iconMenu?.classList.toggle('hidden', isOpen)
    iconClose?.classList.toggle('hidden', !isOpen)
    labelOpen?.classList.toggle('hidden', isOpen)
    labelClose?.classList.toggle('hidden', !isOpen)
  })
</script>
