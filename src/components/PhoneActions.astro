---
import { Icon } from 'astro-icon/components'
import { contact } from '../data/contact'
---

<div class="flex flex-wrap gap-2 mt-3">
  <a
    href={contact.phoneHref}
    data-track="call_contact"
    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-md border border-stone-200 text-stone-600 hover:border-ridge-300 hover:text-ridge-600 transition-colors"
  >
    <Icon name="lucide:phone" class="h-3.5 w-3.5" />
    Call
  </a>
  <a
    href={`sms:${contact.phoneRaw}`}
    data-track="text_contact"
    class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-md border border-stone-200 text-stone-600 hover:border-ridge-300 hover:text-ridge-600 transition-colors"
  >
    <Icon name="lucide:message-square" class="h-3.5 w-3.5" />
    Text
  </a>
</div>

