---
import { Icon } from 'astro-icon/components'
import { contact } from '../data/contact'

interface Props {
  heading: string
  description: string
  primaryLabel?: string
  primaryHref?: string
}

const {
  heading,
  description,
  primaryLabel = 'Request Free Quote',
  primaryHref = '/contact',
} = Astro.props
---

<section class="py-20 lg:py-24 bg-ridge-700 text-white">
  <div class="container-wide section-padding">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-display text-3xl sm:text-4xl font-bold mb-6">
        {heading}
      </h2>
      <p class="text-xl text-ridge-200 mb-10">
        {description}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={primaryHref}
          class="inline-flex items-center justify-center gap-2 bg-white text-ridge-700 hover:bg-stone-100 px-8 py-4 rounded-lg font-medium transition-colors"
        >
          {primaryLabel}
          <Icon name="lucide:arrow-right" class="h-5 w-5" />
        </a>
        <a
          href={contact.phoneHref}
          class="inline-flex items-center justify-center gap-2 bg-ridge-600 text-white hover:bg-ridge-500 px-8 py-4 rounded-lg font-medium transition-colors border border-ridge-500"
        >
          <Icon name="lucide:phone" class="h-5 w-5" />
          {contact.phone}
        </a>
      </div>
    </div>
  </div>
</section>
