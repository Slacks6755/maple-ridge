---
import { Icon } from 'astro-icon/components'
import Logo from './Logo.astro'
import { contact } from '../data/contact'
import { services } from '../data/services'
import { serviceAreas } from '../data/service-areas'

const currentYear = new Date().getFullYear()
---

<footer class="bg-stone-900 text-stone-300">
  <div class="container-wide section-padding py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          <Logo class="h-10 w-10" />
          <div class="flex flex-col">
            <span class="font-display font-semibold text-lg text-white leading-tight">Maple Ridge</span>
            <span class="text-xs text-stone-400 leading-tight">Construction & Development</span>
          </div>
        </a>
        <p class="text-stone-400 text-sm leading-relaxed mb-6">
          Licensed General Contractor serving Southeast Tennessee. New construction, remodeling, and land development.
        </p>
        <div class="space-y-3 text-sm">
          <a href={contact.phoneHref} class="flex items-center gap-3 hover:text-white transition-colors">
            <Icon name="lucide:phone" class="h-4 w-4 text-ridge-400" />
            {contact.phone}
          </a>
          <a href={contact.emailHref} class="flex items-center gap-3 hover:text-white transition-colors">
            <Icon name="lucide:mail" class="h-4 w-4 text-ridge-400" />
            {contact.email}
          </a>
          <div class="flex items-start gap-3">
            <Icon name="lucide:map-pin" class="h-4 w-4 text-ridge-400 mt-0.5" />
            <span>{contact.address.full}</span>
          </div>
          <div class="flex items-start gap-3">
            <Icon name="lucide:clock" class="h-4 w-4 text-ridge-400 mt-0.5" />
            <span>{contact.hours}</span>
          </div>
        </div>
      </div>

      <div>
        <h3 class="font-display font-semibold text-white mb-6">Our Services</h3>
        <ul class="space-y-3">
          {services.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-stone-400 hover:text-white transition-colors text-sm"
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-display font-semibold text-white mb-6">Service Areas</h3>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-3">
          {serviceAreas.map((area) => (
            <li>
              <a
                href={`/service-areas/${area.slug}/`}
                class="text-stone-400 hover:text-white transition-colors text-sm"
              >
                {area.name}
              </a>
            </li>
          ))}
        </ul>
        <p class="text-stone-500 text-xs mt-4">
          Serving McMinn, Bradley, Polk & Monroe Counties
        </p>
      </div>

      <div>
        <h3 class="font-display font-semibold text-white mb-6">Company</h3>
        <ul class="space-y-3">
          <li>
            <a href="/projects/" class="text-stone-400 hover:text-white transition-colors text-sm">
              Projects
            </a>
          </li>
          <li>
            <a href="/about/" class="text-stone-400 hover:text-white transition-colors text-sm">
              About Us
            </a>
          </li>
          <li>
            <a href="/contact/" class="text-stone-400 hover:text-white transition-colors text-sm">
              Contact
            </a>
          </li>
        </ul>
        <div class="mt-8 p-4 bg-stone-800 rounded-lg">
          <p class="text-sm text-stone-400 mb-3">Ready to start your project?</p>
          <a
            href="/contact/"
            class="btn-primary w-full text-center text-sm"
          >
            Get a Free Quote
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-stone-800">
    <div class="container-wide section-padding py-6">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-stone-500">
        <p>
          &copy; {currentYear} Maple Ridge Construction & Development. All rights reserved.
        </p>
        <div class="flex items-center gap-4 sm:gap-6">
          <span class="hidden sm:inline">Licensed General Contractor &bull; Tennessee</span>
          <a
            href={contact.googleBusinessUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-stone-500 hover:text-stone-400 transition-colors text-sm"
          >
            Find us on Google
          </a>
          <a href="/sitemap.xml" class="text-stone-500 hover:text-stone-400 transition-colors text-sm">
            Sitemap
          </a>
          <a
            href="https://www.smbhelp.co"
            target="_blank"
            rel="noopener noreferrer"
            class="text-stone-500 hover:text-stone-400 transition-colors text-sm"
            aria-label="Website by SMB Help"
          >
            Site by SMB Help
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
