---
---

<div class="card p-8 lg:p-10" data-contact-form-root>
  <h3 class="font-display text-2xl font-semibold text-stone-900 tracking-tight mb-2">
    Request a free estimate
  </h3>
  <p class="text-sm text-stone-500 mb-8">Tell us a little about the job and we&apos;ll get back to you.</p>

  <div
    class="hidden p-4 mb-6 rounded-sm border-l-2 border-red-600 bg-red-50 text-red-700 text-sm"
    data-error
    role="alert"
  >
    Something went wrong. Please try again or give us a call.
  </div>

  <form
    name="contact"
    method="POST"
    action="/"
    data-netlify="true"
    data-netlify-honeypot="bot-field"
    class="space-y-6"
    data-contact-form
  >
    <input type="hidden" name="form-name" value="contact" />
    <p class="hidden">
      <label>Don't fill this out: <input name="bot-field" /></label>
    </p>

    <div>
      <label for="name" class="block text-sm font-medium text-stone-700 mb-2">Name *</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        class="w-full px-4 py-3 rounded-sm border border-stone-300 bg-white focus:border-ridge-500 focus:ring-2 focus:ring-ridge-500/20 transition-colors"
      />
    </div>

    <div>
      <label for="phone" class="block text-sm font-medium text-stone-700 mb-2">Phone Number *</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        autocomplete="tel"
        class="w-full px-4 py-3 rounded-sm border border-stone-300 bg-white focus:border-ridge-500 focus:ring-2 focus:ring-ridge-500/20 transition-colors"
      />
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-stone-700 mb-2">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        autocomplete="email"
        class="w-full px-4 py-3 rounded-sm border border-stone-300 bg-white focus:border-ridge-500 focus:ring-2 focus:ring-ridge-500/20 transition-colors"
      />
    </div>

    <div>
      <label for="message" class="block text-sm font-medium text-stone-700 mb-2">Project Details *</label>
      <textarea
        id="message"
        name="message"
        rows="6"
        required
        placeholder="Tell us what you're looking to build, renovate, or develop..."
        class="w-full px-4 py-3 rounded-sm border border-stone-300 bg-white focus:border-ridge-500 focus:ring-2 focus:ring-ridge-500/20 transition-colors resize-none"
      ></textarea>
    </div>

    <button
      type="submit"
      class="btn-primary w-full justify-center disabled:opacity-60 disabled:cursor-not-allowed"
      data-submit
    >
      <span data-submit-idle>Send message</span>
      <span class="hidden" data-submit-busy>Sending&hellip;</span>
    </button>
  </form>

  <div
    class="hidden flex flex-col items-center justify-center text-center min-h-[400px]"
    data-success
  >
    <p class="font-display text-3xl font-semibold text-ridge-700 mb-3">Message sent</p>
    <p class="text-stone-600">Thanks for reaching out. We&apos;ll be in touch!</p>
  </div>
</div>

<script>
  const root = document.querySelector<HTMLElement>('[data-contact-form-root]')
  const form = root?.querySelector<HTMLFormElement>('[data-contact-form]')
  const error = root?.querySelector<HTMLElement>('[data-error]')
  const success = root?.querySelector<HTMLElement>('[data-success]')
  const submit = root?.querySelector<HTMLButtonElement>('[data-submit]')
  const labelIdle = root?.querySelector<HTMLElement>('[data-submit-idle]')
  const labelBusy = root?.querySelector<HTMLElement>('[data-submit-busy]')

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    error?.classList.add('hidden')
    submit?.setAttribute('disabled', '')
    labelIdle?.classList.add('hidden')
    labelBusy?.classList.remove('hidden')

    try {
      const data = new URLSearchParams(new FormData(form) as unknown as Record<string, string>)
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: data.toString(),
      })
      if (!res.ok) throw new Error('submission failed')
      form.classList.add('hidden')
      error?.classList.add('hidden')
      success?.classList.remove('hidden')
    } catch {
      error?.classList.remove('hidden')
    } finally {
      submit?.removeAttribute('disabled')
      labelIdle?.classList.remove('hidden')
      labelBusy?.classList.add('hidden')
    }
  })
</script>
