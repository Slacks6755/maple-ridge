---
import { contact } from '../data/contact'

interface Props {
  label: string
  title: string
  description: string
  showCTA?: boolean
  ctaLabel?: string
  ctaHref?: string
}

const {
  label,
  title,
  description,
  showCTA = true,
  ctaLabel = 'Get a free estimate',
  ctaHref = '/contact',
} = Astro.props
---

<section class="bg-stone-900 text-white py-20 lg:py-28 relative overflow-hidden texture-overlay">
  <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-ridge-500"></div>

  <div class="container-wide section-padding relative">
    <div class="max-w-3xl">
      <span class="inline-block text-ridge-400 font-semibold text-xs uppercase tracking-[0.22em] mb-5">
        {label}
      </span>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
        {title}
      </h1>
      <p class="text-xl text-stone-300 leading-relaxed">
        {description}
      </p>
      {showCTA && (
        <div class="flex flex-col sm:flex-row gap-4 mt-10">
          <a
            href={ctaHref}
            class="inline-flex items-center justify-center bg-ridge-500 hover:bg-ridge-600 text-white px-7 py-3.5 rounded-sm font-medium transition-colors"
          >
            {ctaLabel}
          </a>
          <a
            href={contact.phoneHref}
            data-track="call_page_hero"
            class="inline-flex items-center justify-center bg-transparent hover:bg-white/5 text-white px-7 py-3.5 rounded-sm font-medium transition-colors border border-white/25"
          >
            <span class="lg:hidden">Call&nbsp;</span>{contact.phone}
          </a>
        </div>
      )}
    </div>
  </div>
</section>
