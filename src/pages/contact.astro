---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/PageHero.astro'
import CopyButton from '../components/CopyButton.astro'
import ContactForm from '../components/ContactForm.astro'
import { contact } from '../data/contact'
import { serviceAreas } from '../data/service-areas'

const title = 'Get a Free Estimate | Maple Ridge Construction'
const description = `Contact Maple Ridge Construction for a free estimate. Licensed general contractor serving Etowah and Southeast Tennessee. Call ${contact.phone} or email ${contact.email}.`
---

<BaseLayout title={title} description={description}>
  <PageHero
    label="Contact us"
    title="Let's talk about your project"
    description="Ready to build, renovate, or develop? Reach out for a free estimate."
    showCTA={false}
  />

  <section class="py-20 lg:py-28">
    <div class="container-wide section-padding">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <span class="section-label">Get in touch</span>
          <h2 class="section-title">Contact information</h2>
          <p class="section-subtitle">
            Reach out by phone or email, or fill out the form and we&apos;ll be in touch!
          </p>

          <dl class="mt-10 border-t border-stone-300">
            <div class="py-6 border-b border-stone-200 grid sm:grid-cols-[7rem,1fr] gap-2 sm:gap-6">
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500 pt-1">Phone</dt>
              <dd>
                <a href={contact.phoneHref} data-track="call_contact_info" class="font-display text-xl text-stone-900 hover:text-ridge-800 transition-colors">
                  {contact.phone}
                </a>
                <div class="mt-3">
                  <CopyButton value={contact.phone} label="Copy number" track="copy_phone_contact" />
                </div>
              </dd>
            </div>

            <div class="py-6 border-b border-stone-200 grid sm:grid-cols-[7rem,1fr] gap-2 sm:gap-6">
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500 pt-1">Email</dt>
              <dd>
                <span class="font-display text-xl text-stone-900">{contact.email}</span>
                <div class="mt-3">
                  <CopyButton value={contact.email} label="Copy address" track="copy_email_contact" />
                </div>
              </dd>
            </div>

            <div class="py-6 border-b border-stone-200 grid sm:grid-cols-[7rem,1fr] gap-2 sm:gap-6">
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500 pt-1">Address</dt>
              <dd class="text-stone-700">{contact.address.full}</dd>
            </div>

            <div class="py-6 border-b border-stone-200 grid sm:grid-cols-[7rem,1fr] gap-2 sm:gap-6">
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500 pt-1">Hours</dt>
              <dd class="text-stone-700">{contact.hours}</dd>
            </div>

            <div class="py-6 border-b border-stone-200 grid sm:grid-cols-[7rem,1fr] gap-2 sm:gap-6">
              <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500 pt-1">Areas</dt>
              <dd class="text-stone-700">
                {serviceAreas.map((area, index) => (
                  <>
                    {index > 0 && <span class="mx-1.5 text-stone-400" aria-hidden="true">&middot;</span>}
                    <a href={`/service-areas/${area.slug}`} class="hover:text-ridge-800 transition-colors whitespace-nowrap">
                      {area.name}
                    </a>
                  </>
                ))}
              </dd>
            </div>
          </dl>
        </div>

        <ContactForm />
      </div>
    </div>
  </section>

  <section class="py-16 bg-white border-t border-stone-200">
    <div class="container-wide section-padding">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-8">
          <h2 class="font-display text-2xl font-bold text-stone-900 tracking-tight mb-2">Where we work</h2>
          <p class="text-stone-600">McMinn, Bradley, Polk, and Monroe Counties</p>
        </div>
        <div class="aspect-[16/10] rounded-lg overflow-hidden border border-stone-200">
          <iframe
            src="https://maps.google.com/maps?q=Maple+Ridge+Construction+%26+Development+Etowah+TN&z=9&output=embed"
            class="w-full h-full"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Map of Maple Ridge Construction service area in Southeast Tennessee"
          ></iframe>
        </div>
        <p class="text-center mt-6">
          <a
            href={contact.googleBusinessUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-link"
          >
            Find us on Google
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-wide section-padding">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-display text-2xl font-bold text-stone-900 tracking-tight mb-3">Prefer to reach out directly?</h2>
        <p class="text-stone-600 mb-8">
          Skip the form. Call or email {contact.owner} and we&apos;ll get your project moving.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={contact.phoneHref} data-track="call_contact_bottom" class="btn-primary">
            <span class="lg:hidden">Call&nbsp;</span>{contact.phone}
          </a>
          <a
            href={contact.emailHref}
            data-track="email_contact_bottom"
            class="btn bg-white text-stone-700 hover:bg-stone-50 border border-stone-300"
          >
            {contact.email}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
