---
import { Icon } from 'astro-icon/components'
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/PageHero.astro'
import PhoneActions from '../components/PhoneActions.astro'
import EmailActions from '../components/EmailActions.astro'
import ContactForm from '../components/ContactForm.astro'
import { contact } from '../data/contact'
import { serviceAreas } from '../data/service-areas'

const title = 'Get a Free Estimate in Etowah, TN'
const description = `Contact Maple Ridge Construction for a free estimate. Licensed general contractor serving Etowah and Southeast Tennessee. Call ${contact.phone} or email ${contact.email}.`
---

<BaseLayout title={title} description={description}>
  <PageHero
    label="Contact Us"
    title="Let's Talk About Your Project"
    description="Ready to build, renovate, or develop? Reach out for a free estimate."
    showCTA={false}
  />

  <section class="py-20 lg:py-28 bg-stone-50">
    <div class="container-wide section-padding">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <span class="section-label">Get in Touch</span>
          <h2 class="section-title">Contact Information</h2>
          <p class="section-subtitle">
            Reach out by phone or email, or fill out the form and we&apos;ll be in touch!
          </p>

          <div class="mt-10 space-y-6">
            <div class="flex gap-5">
              <div class="flex-shrink-0 w-12 h-12 bg-ridge-100 rounded-xl flex items-center justify-center">
                <Icon name="lucide:phone" class="h-6 w-6 text-ridge-600" />
              </div>
              <div>
                <h3 class="font-semibold text-stone-900 mb-1">Phone</h3>
                <a href={contact.phoneHref} class="text-stone-700 hover:text-ridge-600 transition-colors">
                  {contact.phone}
                </a>
                <PhoneActions />
              </div>
            </div>

            <div class="flex gap-5">
              <div class="flex-shrink-0 w-12 h-12 bg-ridge-100 rounded-xl flex items-center justify-center">
                <Icon name="lucide:mail" class="h-6 w-6 text-ridge-600" />
              </div>
              <div>
                <h3 class="font-semibold text-stone-900 mb-1">Email</h3>
                <span class="text-stone-700">{contact.email}</span>
                <EmailActions />
              </div>
            </div>

            <div class="flex gap-5">
              <div class="flex-shrink-0 w-12 h-12 bg-ridge-100 rounded-xl flex items-center justify-center">
                <Icon name="lucide:map-pin" class="h-6 w-6 text-ridge-600" />
              </div>
              <div>
                <h3 class="font-semibold text-stone-900 mb-1">Location</h3>
                <p class="text-stone-700">{contact.address.full}</p>
              </div>
            </div>

            <div class="flex gap-5">
              <div class="flex-shrink-0 w-12 h-12 bg-ridge-100 rounded-xl flex items-center justify-center">
                <Icon name="lucide:clock" class="h-6 w-6 text-ridge-600" />
              </div>
              <div>
                <h3 class="font-semibold text-stone-900 mb-1">Hours</h3>
                <p class="text-stone-700">{contact.hours}</p>
              </div>
            </div>
          </div>

          <div class="mt-12 p-6 bg-white rounded-xl border border-stone-200">
            <h3 class="font-semibold text-stone-900 mb-4">Service Areas</h3>
            <div class="grid grid-cols-2 gap-2">
              {serviceAreas.map((area) => (
                <a
                  href={`/service-areas/${area.slug}`}
                  class="text-sm text-stone-600 hover:text-ridge-600"
                >
                  {area.name}, {contact.address.region}
                </a>
              ))}
            </div>
          </div>
        </div>

        <ContactForm />
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container-wide section-padding">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-8">
          <h2 class="font-display text-2xl font-bold text-stone-900 mb-2">Where We Work</h2>
          <p class="text-stone-600">McMinn, Bradley, Polk, and Monroe Counties</p>
        </div>
        <div class="aspect-[16/10] rounded-2xl overflow-hidden border border-stone-200 shadow-sm">
          <iframe
            src="https://maps.google.com/maps?q=Maple+Ridge+Construction+%26+Development+Etowah+TN&z=9&output=embed"
            class="w-full h-full"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Map of Maple Ridge Construction service area in Southeast Tennessee"
          ></iframe>
        </div>
        <p class="text-center mt-6">
          <a
            href={contact.googleBusinessUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-ridge-700 font-medium hover:text-ridge-800"
          >
            <Icon name="lucide:map-pin" class="h-4 w-4" />
            Find us on Google
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-100">
    <div class="container-wide section-padding">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-display text-2xl font-bold text-stone-900 mb-3">Prefer to Reach Out Directly?</h2>
        <p class="text-stone-600 mb-8">
          Skip the form. Call or email {contact.owner} and we&apos;ll get your project moving.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={contact.phoneHref} class="btn-primary">
            <Icon name="lucide:phone" class="mr-2 h-5 w-5" />
            {contact.phone}
          </a>
          <a
            href={contact.emailHref}
            class="btn bg-white text-stone-700 hover:bg-stone-50 border border-stone-300"
          >
            <Icon name="lucide:mail" class="mr-2 h-5 w-5" />
            {contact.email}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
