---
import { Picture } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import BaseLayout from '../layouts/BaseLayout.astro'
import CTASection from '../components/CTASection.astro'
import { contact } from '../data/contact'
import { services } from '../data/services'
import { serviceAreas } from '../data/service-areas'
import heroKitchen from '../assets/projects/central-house/after/IMG_2378.webp'
import heroBathroom from '../assets/projects/central-house/after/IMG_2367.webp'
import heroBarndo from '../assets/projects/barndo-porch/IMG_2028.webp'
---

<BaseLayout canonical={`${contact.url}/`}>
  <section class="relative bg-stone-900 overflow-hidden">
    <div class="container-wide section-padding">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 py-16 lg:py-24">
        <div class="flex flex-col justify-center">
          <div class="inline-flex items-center gap-2 text-ridge-400 text-sm font-medium mb-6">
            <Icon name="lucide:map-pin" class="h-4 w-4" />
            {contact.address.locality}, {contact.address.regionFull}
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold text-white leading-[1.1] tracking-tight">
            General Contractor &amp; Home Builder in Southeast Tennessee
          </h1>

          <p class="mt-6 text-lg text-stone-300 max-w-lg leading-relaxed">
            New construction, renovations, and land development across McMinn, Bradley, Polk, and Monroe Counties. Straightforward pricing, quality work.
          </p>

          <div class="mt-8 flex flex-wrap gap-6">
            <div class="flex items-center gap-2 text-stone-300">
              <Icon name="lucide:shield" class="h-5 w-5 text-ridge-400" />
              <span class="text-sm">Licensed &amp; Insured</span>
            </div>
            <div class="flex items-center gap-2 text-stone-300">
              <Icon name="lucide:check-circle" class="h-5 w-5 text-ridge-400" />
              <span class="text-sm">Locally Owned</span>
            </div>
          </div>

          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a
              href="/contact"
              class="group inline-flex items-center justify-center gap-3 bg-ridge-500 hover:bg-ridge-600 text-white px-8 py-4 rounded-lg font-medium transition-colors"
            >
              Get a free quote
              <Icon name="lucide:arrow-right" class="h-5 w-5 group-hover:translate-x-1 transition-transform" />
            </a>
            <a
              href={contact.phoneHref}
              class="inline-flex items-center justify-center gap-3 bg-white/5 hover:bg-white/10 text-white px-8 py-4 rounded-lg font-medium transition-colors border border-white/10"
            >
              <Icon name="lucide:phone" class="h-5 w-5" />
              {contact.phone}
            </a>
          </div>
        </div>

        <div class="relative hidden lg:flex flex-col justify-center">
          <div class="grid grid-cols-12 gap-3">
            <div class="col-span-5 overflow-hidden rounded-2xl bg-stone-800 aspect-[9/16]">
              <Picture
                src={heroBathroom}
                formats={['avif']}
                fallbackFormat="webp"
                alt="Remodeled bathroom with tiled glass shower"
                widths={[400, 600, 800]}
                sizes="(min-width: 1024px) 20vw, 50vw"
                loading="eager"
                fetchpriority="high"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="col-span-7 flex flex-col gap-3">
              <div class="flex-1 overflow-hidden rounded-2xl bg-stone-800">
                <Picture
                  src={heroKitchen}
                  formats={['avif']}
                  fallbackFormat="webp"
                  alt="Renovated kitchen with new cabinetry and finishes"
                  widths={[500, 800, 1200]}
                  sizes="(min-width: 1024px) 28vw, 100vw"
                  loading="eager"
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="flex-1 overflow-hidden rounded-2xl bg-stone-800">
                <Picture
                  src={heroBarndo}
                  formats={['avif']}
                  fallbackFormat="webp"
                  alt="Covered porch added to a barndominium in Southeast Tennessee"
                  widths={[500, 800, 1200]}
                  sizes="(min-width: 1024px) 28vw, 100vw"
                  loading="eager"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-stone-200">
    <div class="container-wide section-padding">
      <div class="max-w-xl mb-16">
        <h2 class="text-4xl font-display font-bold text-stone-900 mb-4">What we do</h2>
        <p class="text-lg text-stone-600">Full-service construction from start to finish.</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-6">
        {services.map((service, index) => (
          <a
            href={service.href}
            class="group relative bg-white p-8 rounded-2xl border border-stone-200 hover:border-ridge-300 hover:shadow-lg transition-all duration-300 flex flex-col"
          >
            <span class="text-sm font-mono text-stone-400 mb-4 block">0{index + 1}</span>
            <h3 class="text-xl font-semibold text-stone-900 mb-3">{service.name}</h3>
            <p class="text-stone-600 leading-relaxed flex-1">{service.description}</p>
            <span class="mt-6 inline-flex items-center gap-2 text-ridge-700 font-medium">
              Learn more
              <Icon name="lucide:arrow-right" class="h-4 w-4 group-hover:translate-x-1 transition-transform" />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-stone-50">
    <div class="container-wide section-padding">
      <div class="max-w-2xl mx-auto">
        <span class="section-label">A note from Zack</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-stone-900 mb-8">
          How we work, and why
        </h2>

        <div class="space-y-5 text-lg text-stone-700 leading-relaxed font-display">
          <p>
            I started Maple Ridge because I wanted to do this work the way it should be done.
            I studied civil engineering at the University of Tennessee, put in a few years at
            Kimley-Horn, then came back to Etowah to build.
          </p>
          <p>
            You'll get my number. When you call, I answer. If I'm on a roof, you'll hear back
            in an hour.
          </p>
          <p>
            We don't bid every job and we don't take on more than we can finish well. The crews
            we run care what the work looks like at the end. That sounds simple. It's the whole
            thing.
          </p>
          <p>
            Got a build, a remodel, or a piece of land you want to do something with? Let's
            talk.
          </p>
        </div>

        <div class="mt-10 flex items-center justify-between flex-wrap gap-6 pt-8 border-t border-stone-200">
          <div>
            <p class="font-display text-xl text-stone-900">Zack Newman</p>
            <p class="text-sm text-stone-500">Owner, Maple Ridge Construction</p>
          </div>
          <div class="flex items-center gap-4">
            <a href={contact.phoneHref} class="inline-flex items-center gap-2 text-ridge-700 font-medium hover:text-ridge-800">
              <Icon name="lucide:phone" class="h-4 w-4" />
              {contact.phone}
            </a>
            <a href="/about" class="inline-flex items-center gap-2 text-stone-600 font-medium hover:text-ridge-700">
              More about us
              <Icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container-wide section-padding">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-display font-bold text-stone-900 mb-4">
          Serving Southeast Tennessee
        </h2>
        <p class="text-stone-600">McMinn, Bradley, Polk, and Monroe Counties</p>
      </div>

      <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
        {serviceAreas.map((area) => (
          <a
            href={`/service-areas/${area.slug}`}
            class="inline-flex items-center gap-2 bg-white border border-stone-200 px-5 py-2.5 rounded-full text-stone-700 hover:border-ridge-300 hover:text-ridge-700 transition-colors"
          >
            <Icon name="lucide:map-pin" class="h-4 w-4 text-ridge-500" />
            {area.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to get started?"
    description="Give us a call or send a message. We'll talk through your project and give you an honest number."
  />
</BaseLayout>
