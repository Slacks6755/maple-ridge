---
import { Picture } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'
import CTASection from '../components/CTASection.astro'
import Reviews from '../components/Reviews.astro'
import { contact } from '../data/contact'
import { services } from '../data/services'
import { serviceAreas } from '../data/service-areas'
import heroKitchen from '../assets/projects/central-house/after/IMG_2378.webp'
import heroBathroom from '../assets/projects/central-house/after/IMG_2367.webp'
import heroBarndo from '../assets/projects/barndo-porch/IMG_2028.webp'
---

<BaseLayout>
  <section class="relative bg-stone-900 overflow-hidden texture-overlay">
    <div class="container-wide section-padding">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 py-16 lg:py-24">
        <div class="flex flex-col justify-center">
          <span class="text-ridge-400 text-xs font-semibold uppercase tracking-[0.22em] mb-6">
            {contact.address.locality}, {contact.address.regionFull}
          </span>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold text-white leading-[1.1] tracking-tight">
            General Contractor &amp; Home Builder in Southeast Tennessee
          </h1>

          <p class="mt-6 text-lg text-stone-300 max-w-lg leading-relaxed">
            New construction, renovations, and land development across McMinn, Bradley, Polk, and Monroe Counties. Straightforward pricing, quality work.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a
              href="/contact"
              class="inline-flex items-center justify-center bg-ridge-500 hover:bg-ridge-600 text-white px-8 py-4 rounded-sm font-medium transition-colors"
            >
              Get a free quote
            </a>
            <a
              href={contact.phoneHref}
              data-track="call_hero"
              class="inline-flex items-center justify-center bg-transparent hover:bg-white/5 text-white px-8 py-4 rounded-sm font-medium transition-colors border border-white/25"
            >
              <span class="lg:hidden">Call&nbsp;</span>{contact.phone}
            </a>
          </div>

          <p class="mt-10 pt-6 border-t border-white/10 text-xs uppercase tracking-[0.18em] text-stone-400">
            Licensed &amp; insured
            <span class="mx-2 text-stone-600" aria-hidden="true">&middot;</span>
            Locally owned
            <span class="mx-2 text-stone-600" aria-hidden="true">&middot;</span>
            Free estimates
          </p>
        </div>

        <div class="relative hidden lg:flex flex-col justify-center">
          <div class="grid grid-cols-12 gap-3">
            <div class="col-span-5 overflow-hidden rounded-lg bg-stone-800 aspect-[9/16]">
              <Picture
                src={heroBathroom}
                formats={['avif']}
                fallbackFormat="webp"
                alt="Remodeled bathroom with tiled glass shower"
                widths={[400, 600, 800]}
                sizes="(min-width: 1024px) 20vw, 50vw"
                loading="eager"
                fetchpriority="high"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="col-span-7 flex flex-col gap-3">
              <div class="flex-1 overflow-hidden rounded-lg bg-stone-800">
                <Picture
                  src={heroKitchen}
                  formats={['avif']}
                  fallbackFormat="webp"
                  alt="Renovated kitchen with new cabinetry and finishes"
                  widths={[500, 800, 1200]}
                  sizes="(min-width: 1024px) 28vw, 100vw"
                  loading="eager"
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="flex-1 overflow-hidden rounded-lg bg-stone-800">
                <Picture
                  src={heroBarndo}
                  formats={['avif']}
                  fallbackFormat="webp"
                  alt="Covered porch added to a barndominium in Southeast Tennessee"
                  widths={[500, 800, 1200]}
                  sizes="(min-width: 1024px) 28vw, 100vw"
                  loading="eager"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container-wide section-padding">
      <div class="max-w-xl mb-14">
        <span class="section-label">What we do</span>
        <h2 class="text-4xl font-display font-bold text-stone-900 tracking-tight mb-4">Three things, done well</h2>
        <p class="text-lg text-stone-600">Full-service construction from start to finish.</p>
      </div>

      <div class="border-t border-stone-300">
        {services.map((service, index) => (
          <a
            href={service.href}
            class="group grid md:grid-cols-12 gap-4 md:gap-8 items-baseline py-8 border-b border-stone-200 transition-colors hover:bg-earth-50"
          >
            <span class="md:col-span-1 font-display text-lg text-stone-400" aria-hidden="true">0{index + 1}</span>
            <h3 class="md:col-span-4 font-display text-2xl font-semibold text-stone-900 group-hover:text-ridge-800 transition-colors">
              {service.name}
            </h3>
            <p class="md:col-span-5 text-stone-600 leading-relaxed">{service.description}</p>
            <span class="md:col-span-2 md:text-right text-link">Learn more</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="container-wide section-padding">
      <div class="max-w-2xl mx-auto">
        <span class="section-label">A note from Zack</span>
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-stone-900 tracking-tight mb-8">
          How we work, and why
        </h2>

        <div class="space-y-5 text-lg text-stone-700 leading-relaxed font-display">
          <p>
            I started Maple Ridge because I wanted to do this work the way it should be done.
            I studied civil engineering at the University of Tennessee, put in a few years at
            Kimley-Horn, then came back to Etowah to build.
          </p>
          <p>
            You'll get my number. When you call, I answer. If I'm on a roof, you'll hear back
            in an hour.
          </p>
          <p>
            We don't bid every job and we don't take on more than we can finish well. The crews
            we run care what the work looks like at the end. That sounds simple. It's the whole
            thing.
          </p>
          <p>
            Got a build, a remodel, or a piece of land you want to do something with? Let's
            talk.
          </p>
        </div>

        <div class="mt-10 flex items-center justify-between flex-wrap gap-6 pt-8 border-t border-stone-300">
          <div>
            <p class="font-display text-xl text-stone-900">Zack Newman</p>
            <p class="text-sm text-stone-500">Owner, Maple Ridge Construction</p>
          </div>
          <div class="flex items-center gap-6">
            <a href={contact.phoneHref} data-track="call_home_note" class="text-link">
              {contact.phone}
            </a>
            <a href="/about" class="text-link">
              More about us
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-stone-200">
    <div class="container-wide section-padding">
      <div class="text-center mb-10">
        <span class="section-label">Where we work</span>
        <h2 class="text-3xl font-display font-bold text-stone-900 tracking-tight mb-3">
          Serving Southeast Tennessee
        </h2>
        <p class="text-stone-600">McMinn, Bradley, Polk, and Monroe Counties</p>
      </div>

      <p class="text-center max-w-3xl mx-auto font-display text-2xl sm:text-3xl leading-relaxed text-stone-900">
        {serviceAreas.map((area, index) => (
          <>
            {index > 0 && <span class="mx-3 text-stone-300" aria-hidden="true">&middot;</span>}
            <a
              href={`/service-areas/${area.slug}`}
              class="whitespace-nowrap underline decoration-stone-300 decoration-1 underline-offset-[6px] hover:decoration-ridge-600 hover:text-ridge-800 transition-colors"
            >
              {area.name}
            </a>
          </>
        ))}
      </p>
    </div>
  </section>

  <Reviews />

  <CTASection
    heading="Ready to get started?"
    description="Give us a call or send a message. We'll talk through your project and give you an honest number."
  />
</BaseLayout>
