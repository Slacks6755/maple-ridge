---
import { Icon } from 'astro-icon/components'
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Page Not Found" noindex>
  <div class="min-h-[60vh] flex items-center justify-center bg-stone-50">
    <div class="container-wide section-padding py-20 text-center">
      <h1 class="font-display text-6xl font-bold text-ridge-600 mb-4">404</h1>
      <h2 class="font-display text-2xl font-semibold text-stone-900 mb-4">
        Page Not Found
      </h2>
      <p class="text-stone-600 mb-8 max-w-md mx-auto">
        The page you&apos;re looking for doesn&apos;t exist or has been moved.
        Let&apos;s get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">
          <Icon name="lucide:home" class="mr-2 h-5 w-5" />
          Back to Home
        </a>
        <a href="/contact" class="btn-secondary">
          <Icon name="lucide:arrow-left" class="mr-2 h-5 w-5" />
          Contact Us
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
